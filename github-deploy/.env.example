# OpenClaw 生产环境环境变量
# 复制此文件为 .env 并填入你的真实值

# ============================================
# 必需配置
# ============================================

# OpenClaw Gateway Token（部署脚本会自动生成强密码）
OPENCLAW_GATEWAY_TOKEN=GENERATE_ON_FIRST_RUN

# 飞书应用配置（从飞书开发者后台获取）
LARK_APP_ID=cli_xxxxx
LARK_APP_SECRET=xxxxx

# ============================================
# 可选配置（AI 模型）
# ============================================

# MiniMax API Key
MINIMAX_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# Anthropic API Key
ANTHROPIC_API_KEY=

# ============================================
# 高级配置（一般不需要修改）
# ============================================

# 时区
TZ=Asia/Shanghai

# Node 环境
NODE_ENV=production
