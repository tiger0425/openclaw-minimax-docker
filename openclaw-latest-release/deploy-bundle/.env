# OpenClaw latest release 示例配置

# 必填：网关访问令牌
OPENCLAW_GATEWAY_TOKEN=replace-with-a-strong-token

# 网络绑定参数：默认允许 LAN / 宿主机访问，需要安全模式时改为 loopback
OPENCLAW_BIND=lan

# 可选：宿主机 IP。未设置时优先使用 host-gateway 映射
HOST_IP=

# 可选：MiniMax
MINIMAX_API_KEY=

# 可选：飞书
LARK_APP_ID=
LARK_APP_SECRET=

# 可选：其他模型
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 可选：让 OpenSpace 通过阿里百炼 OpenAI-compatible 接口使用 qwen3.6-plus
# LiteLLM/OpenSpace 在自定义 OpenAI-compatible endpoint 下推荐使用 openai/ 前缀
# 示例：OPENSPACE_MODEL=openai/qwen3.6-plus
OPENSPACE_MODEL=
OPENSPACE_LLM_API_KEY=
# 示例：OPENSPACE_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENSPACE_LLM_API_BASE=
# 高级覆盖：通常留空即可；需要额外请求头或 LiteLLM 参数时再填写 JSON 字符串
OPENSPACE_LLM_EXTRA_HEADERS=
OPENSPACE_LLM_CONFIG=

# PinchTab 外部浏览器服务
PINCHTAB_IMAGE_NAME=registry.cn-shenzhen.aliyuncs.com/yihuzh/pinchtab:v0.8.6
PINCHTAB_URL=http://pinchtab:9867
PINCHTAB_TOKEN=
PINCHTAB_API_VERSION=application/vnd.pinch.v1+json

# OpenSpace AI 自进化引擎（可选）
# 在 https://open-space.cloud 注册获取 Key；不填则仅使用本地技能
OPENSPACE_API_KEY=
OPENSPACE_IMAGE_NAME=registry.cn-shenzhen.aliyuncs.com/yihuzh/openspace:0.1.0
