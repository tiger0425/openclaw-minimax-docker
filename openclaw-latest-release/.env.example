# OpenClaw latest release 示例配置

# 必填：网关访问令牌
OPENCLAW_GATEWAY_TOKEN=replace-with-a-strong-token

# 网络绑定参数：默认允许 LAN / 宿主机访问，需要安全模式时改为 loopback
OPENCLAW_BIND=lan

# 可选：宿主机 IP。未设置时优先使用 host-gateway 映射
HOST_IP=

# 可选：MiniMax
MINIMAX_API_KEY=

# 可选：飞书
LARK_APP_ID=
LARK_APP_SECRET=

# 可选：其他模型
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# PinchTab 外部浏览器服务
PINCHTAB_IMAGE_NAME=registry.cn-shenzhen.aliyuncs.com/yihuzh/pinchtab:v0.8.6
PINCHTAB_URL=http://pinchtab:9867
PINCHTAB_TOKEN=
PINCHTAB_API_VERSION=application/vnd.pinch.v1+json
