# 运行时生成的 JSON 数据（排除，但保留主配置）
openclaw-minimax-docker/openclaw_data/cron/
openclaw-minimax-docker/openclaw_data/devices/
openclaw-minimax-docker/openclaw_data/feishu/
openclaw-minimax-docker/openclaw_data/identity/
