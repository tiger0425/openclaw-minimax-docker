openclaw-minimax-docker/openclaw_data/*.bak
openclaw-minimax-docker/openclaw_data/update-check.json
# 排除其他运行时 JSON，但保留 openclaw.json 模板
openclaw-minimax-docker/openclaw_data/agents/**/*.json
openclaw-minimax-docker/openclaw_data/browser/**/*.json
openclaw-minimax-docker/openclaw_data/media/
